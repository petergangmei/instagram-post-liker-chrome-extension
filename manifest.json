{
  "manifest_version": 3,
  "name": "Instagram Liker",
  "version": "1.0",
  "description": "Automatically likes Instagram posts and navigates to the next one.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.instagram.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}
